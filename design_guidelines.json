  "instructions_to_main_agent": {
    "steps": [
      "1. Install required packages: `yarn add framer-motion clsx tailwind-merge lucide-react`.",
      "2. Update `tailwind.config.js` to include custom colors and fonts (Poppins/Inter).",
      "3. Create the `Header` component with glassmorphism and sticky positioning.",
      "4. Build the `Hero` section using the split layout or 'Kinetic Texture' concept.",
      "5. Implement the `Showcase` section using the 'Bento Grid' (Mode A).",
      "6. Build the `SocialProof` counters using `framer-motion` for counting up.",
      "7. Create `Housing`, `Jobs`, `Donations` sections using the image URLs provided.",
      "8. Ensure all cards have `data-testid` attributes.",
      "9. Add the 'Noise Texture' overlay to the entire body."
    ],
    "critical_rules": [
      "DO NOT use generic centered text for everything.",
      "Use 'sonner' for toasts.",
      "Ensure text contrast meets AA standards.",
      "Use `lucide-react` for icons.",
      "Mobile-first: Check responsiveness for the Bento Grid."
    ]
  },
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "You tend to converge toward generic, 'on distribution' outputs. Avoid this.",
    "Don't make generic centered layouts, simplistic gradients, and uniform styling.",
    "Create depth through layered design elements with z-index hierarchy.",
    "Use glass-morphism effects with backdrop filters (12-24px blur).",
    "Every interaction needs micro-animations.",
    "Use 2-3x more spacing than feels comfortable.",
    "Subtle grain textures, noise overlays, custom cursors.",
    "Main agent relies on these image URLs. Missing categories = placeholder text which is FORBIDDEN."
  ]
}