{
  "identity": {
    "persona": "E1",
    "mission": "Create a premium, modern student community showcase that feels like a tech product, not a bulletin board.",
    "principles": [
      "Fusion over Imitation: Mix student vibes with SaaS precision.",
      "Emotion First: Trust, Growth, Connection.",
      "Content is King: Every card tells a story.",
      "Zoom In: High-quality imagery.",
      "Negative Space: Luxurious padding."
    ]
  },
  "theme": {
    "mode": "light",
    "strategy": "Modern Clean",
    "background_base": "#F5F7FA"
  },
  "colors": {
    "primary": "#1E5AA8",
    "secondary": "#4CAF50",
    "background": "#F5F7FA",
    "foreground": "#0B1B2B",
    "muted": "#E2E8F0",
    "card": "#FFFFFF",
    "border": "#E2E8F0",
    "accents": {
      "success": "#4CAF50",
      "warning": "#F59E0B",
      "error": "#EF4444"
    },
    "gradients": {
      "hero": "linear-gradient(135deg, #1E5AA8 0%, #4CAF50 100%)",
      "glass": "rgba(255, 255, 255, 0.7)"
    }
  },
  "typography": {
    "font_family_heading": "Poppins, sans-serif",
    "font_family_body": "Inter, sans-serif",
    "weights": {
      "heading": "600",
      "body": "400",
      "bold": "700"
    },
    "tracking": {
      "heading": "-0.02em",
      "overline": "0.1em"
    }
  },
  "layout_strategy": {
    "container": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
    "spacing_scale": "relaxed",
    "grid_system": "Bento Grid (Mode A for Showcase)",
    "section_spacing": "py-24 md:py-32"
  },
  "components": {
    "buttons": {
      "style": "pill",
      "interaction": "transform hover:-translate-y-1 hover:shadow-lg transition-all duration-300",
      "primary": "bg-[#1E5AA8] text-white hover:bg-[#16437E]",
      "secondary": "bg-[#4CAF50] text-white hover:bg-[#3D8B40]"
    },
    "cards": {
      "style": "glass-morphism",
      "border": "border border-white/20",
      "shadow": "shadow-xl shadow-blue-900/5",
      "hover": "hover:shadow-2xl hover:scale-[1.02] transition-all duration-300"
    },
    "inputs": {
      "style": "flat-solid",
      "radius": "rounded-xl",
      "border": "border-gray-200 focus:border-[#1E5AA8] focus:ring-2 focus:ring-[#1E5AA8]/20"
    }
  },
  "motion": {
    "library": "framer-motion",
    "default_transition": {
      "type": "spring",
      "stiffness": 260,
      "damping": 20
    },
    "scroll_reveal": "whileInView={{ opacity: 1, y: 0 }} initial={{ opacity: 0, y: 20 }} viewport={{ once: true }}"
  },
  "visual_enhancers": {
    "glassmorphism": "backdrop-blur-xl bg-white/70 border border-white/20",
    "tracing_beam": "Use for Hero CTA or Featured Cards",
    "noise_texture": "opacity-5 mix-blend-overlay pointer-events-none fixed inset-0 z-50 bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"
  },
